# Copy to .env.local and edit for local dev.

# Backend to talk to. Use Railway in prod, your local NestJS in dev.
NEXT_PUBLIC_API_URL=https://rickbo-production.up.railway.app

# Set to 1 to bypass OTP on the login screen (dev only — pick any phone
# and you're in). Set to 0 to use the real dev-OTP flow
# (`/auth/test-otp/start` + `/auth/test-otp/verify`).
NEXT_PUBLIC_ADMIN_DEV_LOGIN=1
