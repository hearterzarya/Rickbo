# Copy this to .env and fill in your values

# PostgreSQL (must have PostGIS extension enabled).
# On Railway (or any host behind PgBouncer), append these params to avoid the
# two well-known Prisma pitfalls:
#   • client_encoding=UTF8  — prevents Hindi/UTF-8 bytes from being silently
#     replaced with '?' if the pooler hands us a non-UTF-8 session
#     (this was the source of the "? ? ? ? ? ? ?" bug in driver/user names)
#   • pgbouncer=true        — switches Prisma from prepared-statement mode
#     to transaction mode, which PgBouncer requires
#   • connection_limit=1    — keeps Prisma from opening more than one
#     connection per app instance (Railway's free tier allows ~5 total)
DATABASE_URL="postgresql://postgres:password@localhost:5432/rickbo?client_encoding=UTF8&pgbouncer=true&connection_limit=1"

# JWT secret — change before deploying
JWT_SECRET="change-me-to-something-very-long-and-random"

# Firebase Admin SDK (download from Firebase Console > Project Settings > Service Accounts)
FIREBASE_PROJECT_ID="your-firebase-project-id"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com"

# Cloudflare R2 (for photos/evidence — Phase 5)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key"
R2_SECRET_ACCESS_KEY="your-r2-secret"
R2_BUCKET="rickbo-media"

# SMS for SOS alerts (Phase 3)
# Leave the key as the placeholder and SMS is skipped silently (DB log + socket
# alert still fire). To enable: sign up at msg91.com, verify your sender ID,
# and paste the authkey below. Indian DLT registration is required for
# production sends but not for the test free tier.
MSG91_API_KEY="your-msg91-api-key"
MSG91_SENDER_ID="RICKBO"
MSG91_ROUTE="4"

# Admin panel credentials (CHANGE THESE in production!)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="rickbo-admin"
