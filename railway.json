{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "rootDirectory": "backend"
  },
  "deploy": {
    "startCommand": "npm run start:prod",
    "healthcheckPath": "/pricing/zones",
    "healthcheckTimeout": 60,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 5
  }
}
